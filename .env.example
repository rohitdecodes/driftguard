# DriftGuard Environment Configuration
# Copy this file to .env and customize for your environment

# API Key Configuration
# Set a secure API key for accessing protected endpoints
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
DRIFTGUARD_API_KEY=your-secure-api-key-here

# Repository Configuration
# Path to the repository to analyze (inside container: /repo)
HOST_REPO_PATH=./repo
REPO_PATH=/repo

# Watch Mode Configuration
# Interval between analysis runs (e.g., "24h", "12h", "30m", "3600")
WATCH_INTERVAL=24h

# Analysis Configuration
# Number of days of git history to analyze
DRIFTGUARD_DAYS=30

# Maximum number of files to analyze per run
DRIFTGUARD_MAX_FILES=20

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DRIFTGUARD_LOG_LEVEL=INFO

# Alert Configuration (future feature)
# Enable alerts for critical health scores
# ALERT_ENABLED=false
# ALERT_CRITICAL_THRESHOLD=40
# ALERT_EMAIL_TO=team@example.com
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Database Configuration
# Database file path (relative to container /app directory)
# DRIFTGUARD_DB_PATH=data/driftguard.db

# Analysis Cache Configuration
# Enable caching of analysis results to speed up repeated analyses
DRIFTGUARD_CACHE_ENABLED=true

# Cache time-to-live in hours (0 = no expiry, cache never expires)
# Set to a positive number to automatically expire old cache entries
# Example: 168 = 7 days, 720 = 30 days
DRIFTGUARD_CACHE_TTL_HOURS=0

# Rate Limiting Configuration
# Control the rate of Bob analysis calls to prevent overwhelming the system
# BOB_RATE_LIMIT_PER_MINUTE: Maximum number of analysis calls per minute (default: 30)
BOB_RATE_LIMIT_PER_MINUTE=30

# BOB_RATE_LIMIT_BURST: Burst capacity for rapid initial requests (default: 5)
# Allows up to this many requests immediately before rate limiting kicks in
BOB_RATE_LIMIT_BURST=5

# Bob CLI Configuration
# Bob is not installed or configured by this file.
# Install Bob separately and make sure `bob` is available on your PATH if you want AI-generated remediation.
# If Bob is unavailable, DriftGuard will fall back to the built-in deterministic remediation template.

# Language Configuration
# Path to language configuration file (default: data/language_config.json)
# This file defines which file extensions are analyzed and their language mappings
# DRIFTGUARD_LANGUAGE_CONFIG=data/language_config.json

# Parallel Processing Configuration
# Maximum number of parallel workers for file analysis (default: CPU count, max 8)
# DRIFTGUARD_MAX_WORKERS=8

# Made with Bob